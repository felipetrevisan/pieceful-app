{
  "name": "pieceful-app",
  "private": true,
  "packageManager": "bun@1.2.20",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@puzzled/web",
    "dev:api": "turbo run dev --filter=@puzzled/api",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "format": "biome check --write .",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "rm -rf apps/web/.next apps/api/dist"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@types/bun": "1.2.20",
    "turbo": "^2.10.5",
    "typescript": "5.9.2"
  }
}
