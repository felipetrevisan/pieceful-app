EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key

# Google Play Games Services project and achievement IDs from Play Console.
EXPO_PUBLIC_GOOGLE_PLAY_GAMES_APP_ID=000000000000
EXPO_PUBLIC_PLAY_GAMES_FIRST_PUZZLE=
EXPO_PUBLIC_PLAY_GAMES_NO_HINTS=
EXPO_PUBLIC_PLAY_GAMES_PIECES_250=
EXPO_PUBLIC_PLAY_GAMES_PUZZLES_10=

# These defaults may be changed to match the identifiers in App Store Connect.
EXPO_PUBLIC_GAME_CENTER_FIRST_PUZZLE=app.perazzo.pieceful.first_puzzle
EXPO_PUBLIC_GAME_CENTER_NO_HINTS=app.perazzo.pieceful.no_hints
EXPO_PUBLIC_GAME_CENTER_PIECES_250=app.perazzo.pieceful.pieces_250
EXPO_PUBLIC_GAME_CENTER_PUZZLES_10=app.perazzo.pieceful.puzzles_10
